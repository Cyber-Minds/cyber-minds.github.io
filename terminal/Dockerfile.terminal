FROM ubuntu:22.04

# Prevent interactive prompts during build
ENV DEBIAN_FRONTEND=noninteractive

# Enable Ubuntu repositories and install base packages.
# Keep apt lists available so users can install extra packages in live sessions.
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    ca-certificates \
    gnupg \
    lsb-release \
    && add-apt-repository -y universe \
    && apt-get update && apt-get install -y --no-install-recommends \
    curl \
    wget \
    git \
    vim \
    nano \
    htop \
    net-tools \
    iputils-ping \
    nmap \
    build-essential \
    golang-go \
    sudo \
    zsh \
    nginx \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

# Install Python 3.11
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3-pip \
    python3.11-venv \
    && ln -sf /usr/bin/python3.11 /usr/bin/python \
    && ln -sf /usr/bin/python3.11 /usr/bin/python3 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

# Install Node.js 20
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

# Install Java (OpenJDK 17 headless to reduce image size + build disk usage)
RUN apt-get update && apt-get install -y --no-install-recommends \
    openjdk-17-jdk-headless \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

# Configure nginx to run safely as non-root by default.
# This keeps terminal-user in least-privilege mode while allowing `nginx` to start.
RUN printf '%s\n' \
    'worker_processes auto;' \
    'pid /tmp/nginx.pid;' \
    'error_log /tmp/nginx-main-error.log warn;' \
    'include /etc/nginx/modules-enabled/*.conf;' \
    '' \
    'events {' \
    '    worker_connections 768;' \
    '}' \
    '' \
    'http {' \
    '    sendfile on;' \
    '    tcp_nopush on;' \
    '    types_hash_max_size 2048;' \
    '    include /etc/nginx/mime.types;' \
    '    default_type application/octet-stream;' \
    '    ssl_protocols TLSv1 TLSv1.1 TLSv1.2 TLSv1.3;' \
    '    ssl_prefer_server_ciphers on;' \
    '    access_log /tmp/nginx-access.log;' \
    '    client_body_temp_path /tmp/nginx-client-body;' \
    '    proxy_temp_path /tmp/nginx-proxy;' \
    '    fastcgi_temp_path /tmp/nginx-fastcgi;' \
    '    uwsgi_temp_path /tmp/nginx-uwsgi;' \
    '    scgi_temp_path /tmp/nginx-scgi;' \
    '    gzip on;' \
    '    include /etc/nginx/conf.d/*.conf;' \
    '    include /etc/nginx/sites-enabled/*;' \
    '}' > /etc/nginx/nginx.conf \
    && sed -i 's/listen 80 default_server;/listen 9090 default_server;/' /etc/nginx/sites-available/default \
    && sed -i 's/listen \\[::\\]:80 default_server;/listen [::]:9090 default_server;/' /etc/nginx/sites-available/default

# CTF-02: add fake tech-stack headers and deploy custom index page for the recon target
RUN printf '%s\n' \
    'add_header X-Powered-By "PHP/7.4.3" always;' \
    'add_header X-Application "InternalPortal/2.1" always;' \
    > /etc/nginx/conf.d/ctf02-headers.conf \
    && printf '%s\n' \
    '<!DOCTYPE html>' \
    '<html><head><title>Internal Portal</title></head>' \
    '<body><h1>InternalPortal - Employee Dashboard</h1>' \
    '<p>Welcome to the internal company portal.</p>' \
    '</body></html>' \
    > /var/www/html/index.html

# Set Java environment variables
ENV JAVA_HOME=/usr/lib/jvm/default-java
ENV PATH=$PATH:$JAVA_HOME/bin

# Create a non-root user with sudo access
RUN useradd -m -s /bin/bash terminal-user && \
    echo "terminal-user ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Create workspace directory and set ownership
RUN mkdir -p /workspace && \
    chown -R terminal-user:terminal-user /workspace

# CTF-05: privilege escalation log fixtures (SYNTHETIC DATA)
RUN printf '%s\n' \
    '# SYNTHETIC DATA - NOT FROM A REAL INCIDENT' \
    'Jan 15 02:08:42 server sshd[2841]: Failed password for jsmith from 10.0.0.45 port 51234 ssh2' \
    'Jan 15 02:08:55 server sshd[2841]: Failed password for jsmith from 10.0.0.45 port 51234 ssh2' \
    'Jan 15 02:09:03 server sshd[2841]: Failed password for jsmith from 10.0.0.45 port 51234 ssh2' \
    'Jan 15 02:09:17 server sshd[2841]: Accepted password for jsmith from 10.0.0.45 port 51234 ssh2' \
    'Jan 15 02:09:18 server sshd[2841]: pam_unix(sshd:session): session opened for user jsmith' \
    > /workspace/auth.log \
    && printf '%s\n' \
    '# SYNTHETIC DATA - NOT FROM A REAL INCIDENT' \
    'Jan 15 02:11:20 server sudo: jsmith : TTY=pts/0 ; PWD=/home/jsmith ; USER=root ; COMMAND=/bin/su for root' \
    'Jan 15 02:11:20 server sudo: pam_unix(sudo:session): session opened for user root by jsmith(uid=1001)' \
    'Jan 15 02:11:45 server su[3102]: Successful su for root by jsmith' \
    'Jan 15 02:12:01 server su[3102]: pam_unix(su:session): session opened for user root by jsmith(uid=0)' \
    > /workspace/sudo.log

# CTF-05: Python validator embedded in image
RUN printf '%s\n' \
    'import re, sys' \
    'try:' \
    '    with open("/workspace/priv-esc-report.txt") as f:' \
    '        content = f.read()' \
    'except Exception:' \
    '    print("FAIL: cannot read priv-esc-report.txt")' \
    '    sys.exit(1)' \
    'if not content.strip():' \
    '    print("FAIL: priv-esc-report.txt is empty")' \
    '    sys.exit(1)' \
    'checks = [' \
    '    (r"\\bjsmith\\b", "must mention user jsmith"),' \
    '    (r"02:11", "must include timestamp 02:11"),' \
    '    (r"\\bsu\\b|escalat", "must reference su/escalation"),' \
    ']' \
    'for pattern, msg in checks:' \
    '    if not re.search(pattern, content, re.IGNORECASE):' \
    '        print(f"FAIL: {msg}")' \
    '        sys.exit(1)' \
    'print("PASS")' \
    > /workspace/check-priv-esc.py

# CTF-06: incident timeline log fixtures (SYNTHETIC DATA)
RUN printf '%s\n' \
    '# SYNTHETIC DATA - NOT FROM A REAL INCIDENT' \
    'Jan 20 03:10:14 server sshd[4501]: Failed password for admin from 192.168.50.22 port 44312 ssh2' \
    'Jan 20 03:10:29 server sshd[4501]: Failed password for admin from 192.168.50.22 port 44312 ssh2' \
    'Jan 20 03:10:47 server sshd[4501]: Accepted password for admin from 192.168.50.22 port 44312 ssh2' \
    'Jan 20 03:10:48 server sshd[4501]: pam_unix(sshd:session): session opened for user admin' \
    'Jan 20 03:12:05 server sshd[4501]: pam_unix(sshd:session): session closed for user admin' \
    > /workspace/incident-auth.log \
    && printf '%s\n' \
    '# SYNTHETIC DATA - NOT FROM A REAL INCIDENT' \
    '192.168.50.22 - - [20/Jan/2026:03:10:50 +0000] "GET /login HTTP/1.1" 200 512 "-" "curl/7.74.0"' \
    '192.168.50.22 - - [20/Jan/2026:03:11:02 +0000] "POST /login HTTP/1.1" 302 0 "-" "curl/7.74.0"' \
    '192.168.50.22 - - [20/Jan/2026:03:11:05 +0000] "GET /admin HTTP/1.1" 200 4096 "-" "curl/7.74.0"' \
    '192.168.50.22 - - [20/Jan/2026:03:11:33 +0000] "GET /admin/export HTTP/1.1" 200 20480 "-" "curl/7.74.0"' \
    '192.168.50.22 - - [20/Jan/2026:03:12:01 +0000] "GET /logout HTTP/1.1" 200 128 "-" "curl/7.74.0"' \
    > /workspace/incident-access.log \
    && printf '%s\n' \
    '# SYNTHETIC DATA - NOT FROM A REAL INCIDENT' \
    'Jan 20 03:10:47 server kernel: [audit] user admin logged in from 192.168.50.22' \
    'Jan 20 03:11:33 server kernel: [audit] file /var/data/export.csv accessed by admin' \
    'Jan 20 03:11:34 server kernel: [audit] 20480 bytes read from /var/data/export.csv' \
    'Jan 20 03:12:05 server kernel: [audit] user admin session terminated' \
    > /workspace/incident-syslog.log

# CTF-06: Python validator embedded in image
RUN printf '%s\n' \
    'import re, sys' \
    'TS_RE = re.compile(r"\b(\d{2}:\d{2}:\d{2})\b")' \
    'try:' \
    '    with open("/workspace/timeline.txt") as f:' \
    '        lines = [l.rstrip() for l in f if l.strip()]' \
    'except Exception:' \
    '    print("FAIL: cannot read timeline.txt")' \
    '    sys.exit(1)' \
    'if len(lines) < 8:' \
    '    print(f"FAIL: need at least 8 events, got {len(lines)}")' \
    '    sys.exit(1)' \
    'timestamps = []' \
    'for line in lines:' \
    '    m = TS_RE.search(line)' \
    '    if not m:' \
    '        print(f"FAIL: line missing HH:MM:SS timestamp: {line!r}")' \
    '        sys.exit(1)' \
    '    timestamps.append(m.group(1))' \
    'if timestamps != sorted(timestamps):' \
    '    print("FAIL: events are not in ascending time order")' \
    '    sys.exit(1)' \
    'if len(timestamps) != len(set(timestamps)):' \
    '    print("FAIL: duplicate timestamps found")' \
    '    sys.exit(1)' \
    'content = "\n".join(lines)' \
    'if not re.search(r"ssh|login|accept", content, re.IGNORECASE):' \
    '    print("FAIL: no SSH/login event found")' \
    '    sys.exit(1)' \
    'if not re.search(r"http|get|post|request", content, re.IGNORECASE):' \
    '    print("FAIL: no HTTP event found")' \
    '    sys.exit(1)' \
    'print("PASS")' \
    > /workspace/check-timeline.py

# Give terminal-user write access to nginx runtime/log dirs to avoid startup alerts.
RUN mkdir -p /var/log/nginx /var/lib/nginx && \
    chown -R terminal-user:terminal-user /var/log/nginx /var/lib/nginx

WORKDIR /workspace

# Set default user
USER terminal-user

# Set up shell prompt and auto-start nginx for CTF-02 recon target
RUN echo 'export PS1="\[\033[01;36m\]cyberminds\[\033[00m\] \[\033[01;34m\]\w\[\033[00m\] \$ "' >> /home/terminal-user/.bashrc \
    && echo 'sudo nginx -q 2>/dev/null || true' >> /home/terminal-user/.bashrc

# Default command
CMD ["/bin/bash"]
