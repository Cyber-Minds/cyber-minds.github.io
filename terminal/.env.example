# Server Configuration
PORT=3000
ENVIRONMENT=production

# Public domain served by Caddy (required in production)
APP_DOMAIN=terminal.example.com
ACME_EMAIL=ops@example.com

# CORS / WebSocket Origin allowlist (comma-separated if multiple)
# Must match the browser origin exactly (scheme + host [+ port])
ALLOWED_ORIGINS=https://terminal.example.com

# Docker Configuration
# Memory limit: 512MB
# CPU limit: 1 CPU
# Session timeout: 30 minutes
