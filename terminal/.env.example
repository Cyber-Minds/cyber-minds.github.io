# Server Configuration
PORT=3000
ENVIRONMENT=production

# Internal reverse proxy configuration
APP_DOMAIN=terminal.example.com
CADDY_HTTP_PORT=18080

# CORS / WebSocket Origin allowlist (comma-separated if multiple)
# Must match where HTML/terminal.html is served from (main website origin).
# Example:
# ALLOWED_ORIGINS=https://cyber-minds.github.io
# If you paste a full URL like https://cyber-minds.github.io/CyberMinds/,
# backend normalization will strip path/query and keep only scheme+host.
ALLOWED_ORIGINS=https://cyber-minds.github.io

# Light abuse protection (no auth required)
MAX_ACTIVE_SESSIONS=30
SESSION_CREATE_RATE_LIMIT_PER_MINUTE=12

# Docker Configuration
# Memory limit: 512MB
# CPU limit: 1 CPU
# Session timeout: 30 minutes
