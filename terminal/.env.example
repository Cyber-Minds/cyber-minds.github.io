# Server Configuration
PORT=3000
ENVIRONMENT=production

# Backend host binding (bound to 127.0.0.1 only)
TERMINAL_PUBLIC_PORT=18080

# CORS / WebSocket Origin allowlist (comma-separated if multiple)
# Must match the browser origin exactly (scheme + host [+ port])
ALLOWED_ORIGINS=https://terminal.example.com

# Docker Configuration
# Memory limit: 512MB
# CPU limit: 1 CPU
# Session timeout: 30 minutes
