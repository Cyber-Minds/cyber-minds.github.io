{
	# Used only when APP_DOMAIN is a real public domain.
	# Ignored for internal listeners like :80.
	email {$ACME_EMAIL}
}

# APP_DOMAIN can be:
# - terminal.example.com (Caddy serves HTTPS directly)
# - :80 (Caddy serves HTTP only, for use behind another reverse proxy)
{$APP_DOMAIN::80} {
	@api path /api* /health
	handle @api {
		reverse_proxy backend:3000
	}

	handle {
		reverse_proxy backend:3000
	}

	encode zstd gzip

	# Caddy handles WebSocket upgrades automatically.
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}
